rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global safety net - deny all by default
    match /{document=**} {
      allow read, write: if false;
    }

    // Site Images
    match /siteImages/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Rooms
    match /rooms/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Filterable Photo Gallery
    match /gallery/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Villa Gallery
    match /villaGallery/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
